{
    "name": "componenta/http-emitter",
    "description": "PSR-7 response emitter for Componenta",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "componenta/config": "^1.0",
        "psr/http-message": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Componenta\\Http\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "componenta": {
            "config-providers": [
                "Componenta\\Http\\EmitterConfigProvider"
            ]
        }
    }
}
